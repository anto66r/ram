{
  "manifest_version": 3,
  "name": "Video Library",
  "version": "1.0",
  "description": "Add videos to your personal video library",
  "permissions": ["activeTab", "storage", "sidePanel", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Video Library"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
